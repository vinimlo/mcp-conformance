[8.045, "o", "\r\n"]
[8.195, "o", "  \u001b[32m\u2713\u001b[0m tools/list returns valid array \u001b[2m(0ms)\u001b[0m"]
[8.195, "o", "\r\n"]
[8.395, "o", "\r\n"]

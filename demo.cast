[7.045, "o", "\u001b[1mProtocol\u001b[0m"]
[7.045, "o", "\r\n"]
[7.195, "o", "  \u001b[32m\u2713\u001b[0m initialize returns valid result \u001b[2m(355ms)\u001b[0m"]
[7.195, "o", "\r\n"]
[7.345, "o", "  \u001b[32m\u2713\u001b[0m server reports protocol version \u001b[2m(0ms)\u001b[0m"]
[7.345, "o", "\r\n"]
[7.495, "o", "  \u001b[32m\u2713\u001b[0m server reports name and version \u001b[2m(0ms)\u001b[0m"]
[7.495, "o", "\r\n"]
